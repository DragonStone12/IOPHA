#!/usr/bin/env sh

# Fail fast: any gate that errors (frontend tests, ruff, mypy, bandit) aborts the push
# instead of silently letting a failure through. Mirrors .husky/pre-commit.
set -e

npm run test:changed

# Guard: ensure the Python backend passes ruff and mypy before pushing (mirrors CI).
cd "$(git rev-parse --show-toplevel)"

# Shared ruff-resolution helper (single source of truth for both hooks).
. "$(git rev-parse --show-toplevel)/.husky/resolve-ruff.sh"

if ! RUFF=$(resolve_ruff); then
  echo "husky/pre-push: 'ruff' not found in IOPHA-backend/venv/bin or venv/bin."
  echo "Install it in the project virtualenv (e.g. 'pip install ruff') and retry."
  echo "Never use 'git push --no-verify' to bypass these checks."
  exit 1
fi

$RUFF check IOPHA-backend/ && $RUFF format --check IOPHA-backend/

# Guard: ensure the Python backend passes mypy before pushing (mirrors CI).
resolve_mypy() {
  if [ -x IOPHA-backend/venv/bin/mypy ]; then
    echo "IOPHA-backend/venv/bin/mypy"
    return 0
  fi
  if [ -x venv/bin/mypy ]; then
    echo "venv/bin/mypy"
    return 0
  fi
  return 1
}

if MYPY=$(resolve_mypy); then
  echo "Running mypy..."
  $MYPY IOPHA-backend/ || exit 1
else
  echo "husky/pre-push: 'mypy' not found in IOPHA-backend/venv/bin or venv/bin."
  echo "Install it in the project virtualenv (e.g. 'pip install mypy') and retry."
  echo "Never use 'git push --no-verify' to bypass these checks."
  exit 1
fi

# Guard: ensure the Python backend passes bandit before pushing (mirrors CI).
resolve_bandit() {
  if [ -x IOPHA-backend/venv/bin/bandit ]; then
    echo "IOPHA-backend/venv/bin/bandit"
    return 0
  fi
  if [ -x venv/bin/bandit ]; then
    echo "venv/bin/bandit"
    return 0
  fi
  return 1
}

if BANDIT=$(resolve_bandit); then
  echo "Running bandit..."
  $BANDIT -r IOPHA-backend/ -c IOPHA-backend/pyproject.toml --severity-level medium || exit 1
else
  echo "husky/pre-push: 'bandit' not found in IOPHA-backend/venv/bin or venv/bin."
  echo "Install it in the project virtualenv (e.g. 'pip install bandit') and retry."
  echo "Never use 'git push --no-verify' to bypass these checks."
  exit 1
fi

# Guard: ensure the Python backend meets the 80% test coverage threshold before pushing.
resolve_pytest() {
  ROOT=$(git rev-parse --show-toplevel)
  if [ -x "${ROOT}/IOPHA-backend/venv/bin/pytest" ]; then
    echo "${ROOT}/IOPHA-backend/venv/bin/pytest"
    return 0
  fi
  if [ -x "${ROOT}/venv/bin/pytest" ]; then
    echo "${ROOT}/venv/bin/pytest"
    return 0
  fi
  return 1
}

if PYTEST=$(resolve_pytest); then
  echo "Running pytest with coverage..."
  cd IOPHA-backend && $PYTEST tests --cov=app --cov-fail-under=80 || exit 1
else
  echo "husky/pre-push: 'pytest' not found in IOPHA-backend/venv/bin or venv/bin."
  echo "Install it in the project virtualenv (e.g. 'pip install pytest pytest-cov') and retry."
  echo "Never use 'git push --no-verify' to bypass these checks."
  exit 1
fi