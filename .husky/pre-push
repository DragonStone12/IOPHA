#!/usr/bin/env sh

# Fail fast: any gate that errors (frontend tests, ruff, mypy, bandit) aborts the push
# instead of silently letting a failure through. Mirrors .husky/pre-commit.
set -e

npm run test:changed

# Guard: ensure the Python backend passes ruff and mypy before pushing (mirrors CI).
cd "$(git rev-parse --show-toplevel)"

# Shared ruff-resolution helper (single source of truth for both hooks).
. "$(git rev-parse --show-toplevel)/.husky/resolve-ruff.sh"

if ! RUFF=$(resolve_ruff); then
  echo "husky/pre-push: 'ruff' not found on PATH or in ./venv."
  echo "Install it (e.g. 'pip install ruff') and retry, or use 'git push --no-verify' only if you know why."
  exit 1
fi

$RUFF check IOPHA-backend/ && $RUFF format --check IOPHA-backend/

# Guard: ensure the Python backend passes mypy before pushing (mirrors CI).
resolve_mypy() {
  # Priority: the project's venv (IOPHA-backend/venv), where the backend
  # dependencies (e.g. python-stdnum) are actually installed. Falling back to
  # a PATH mypy (e.g. anaconda) would type-check against a different
  # environment that lacks those deps and fail loudly for the wrong reason.
  if [ -x IOPHA-backend/venv/bin/mypy ]; then
    echo "IOPHA-backend/venv/bin/mypy"
    return 0
  fi
  if command -v mypy >/dev/null 2>&1; then
    echo "mypy"
    return 0
  fi
  if command -v python3 >/dev/null 2>&1 && python3 -m mypy --version >/dev/null 2>&1; then
    echo "python3 -m mypy"
    return 0
  fi
  return 1
}

if MYPY=$(resolve_mypy); then
  echo "Running mypy..."
  $MYPY IOPHA-backend/ || exit 1
else
  echo "husky/pre-push: 'mypy' not found on PATH or in ./venv."
  echo "Install it (e.g. 'pip install mypy') and retry, or use 'git push --no-verify' only if you know why."
  exit 1
fi

# Guard: ensure the Python backend passes bandit before pushing (mirrors CI).
resolve_bandit() {
  # Check from repo root, output path valid from repo root
  if [ -x "IOPHA-backend/venv/bin/bandit" ]; then
    echo "IOPHA-backend/venv/bin/bandit"
    return 0
  fi
  if command -v bandit >/dev/null 2>&1; then
    echo "bandit"
    return 0
  fi
  if command -v python3 >/dev/null 2>&1 && python3 -m bandit --version >/dev/null 2>&1; then
    echo "python3 -m bandit"
    return 0
  fi
  return 1
}

if BANDIT=$(resolve_bandit); then
  echo "Running bandit..."
  $BANDIT -r IOPHA-backend/ -c IOPHA-backend/pyproject.toml --severity-level medium || exit 1
else
  echo "husky/pre-push: 'bandit' not found on PATH or in ./venv."
  echo "Install it (e.g. 'pip install bandit') and retry, or use 'git push --no-verify' only if you know why."
  exit 1
fi

# Guard: ensure the Python backend meets the 80% test coverage threshold before pushing.
resolve_pytest() {
  # Check from repo root, but output path valid AFTER 'cd IOPHA-backend'
  if [ -x "IOPHA-backend/venv/bin/pytest" ]; then
    echo "venv/bin/pytest"
    return 0
  fi
  if command -v pytest >/dev/null 2>&1; then
    echo "pytest"
    return 0
  fi
  if command -v python3 >/dev/null 2>&1 && python3 -m pytest --version >/dev/null 2>&1; then
    echo "python3 -m pytest"
    return 0
  fi
  return 1
}

if PYTEST=$(resolve_pytest); then
  echo "Running pytest with coverage..."
  cd IOPHA-backend && $PYTEST tests --cov=app --cov-fail-under=80 || exit 1
else
  echo "husky/pre-push: 'pytest' not found on PATH or in ./venv."
  echo "Install it (e.g. 'pip install pytest pytest-cov') and retry, or use 'git push --no-verify' only if you know why."
  exit 1
fi