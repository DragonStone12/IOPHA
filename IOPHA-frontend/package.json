{
  "name": "iopha-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "echo \"No tests configured yet\" && exit 0",
    "test:changed": "node ../scripts/test-changed.js",
    "cy:open": "cypress open --e2e",
    "cy:run": "cypress run --e2e",
    "test:e2e": "start-server-and-test dev http://localhost:3000 cy:run",
    "cy:update-snapshots": "start-server-and-test dev http://localhost:3000 cy:update-snapshots:core",
    "cy:update-snapshots:core": "cypress run --env updateSnapshots=true",
    "cy:update-snapshots:spec": "start-server-and-test dev http://localhost:3000 'cypress run --env updateSnapshots=true --spec'",
    "cy:clean-diffs": "find cypress-visual-screenshots/diff -type f -name '*.png' -delete",
    "cy:check-steps": "node scripts/check-duplicate-steps.js"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "debug": "^4.4.3",
    "react": "^18.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.1.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.0.0",
    "@eslint/js": "^9.39.4",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@swimlane/cy-mockapi": "^3.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/eslint-plugin-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "cypress": "^15.18.0",
    "cypress-image-diff-js": "^2.8.0",
    "eslint": "^9.0.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-no-secrets": "^0.9.1",
    "eslint-plugin-promise": "^6.6.0",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.1.0",
    "start-server-and-test": "^2.0.0",
    "typescript": "^5.2.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings=0 --fix",
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "overrides": {
    "mocha": "10.8.2",
    "serialize-javascript": "^7.0.5"
  }
}
